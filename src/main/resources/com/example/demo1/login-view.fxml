<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.PasswordField?>

<BorderPane styleClass="background"
            stylesheets="@styles.css"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.demo1.controller.LoginController"
            prefHeight="200" prefWidth="400">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>
    <top>
        <VBox style="-fx-padding: 5">
            <VBox styleClass="panel-bg" VBox.vgrow="ALWAYS">
                <Label style="-fx-font-style: italic; -fx-font-weight: bold; -fx-font-size: 30;" text="Costoso" textFill="#dc1534" />
                <Label style="-fx-font-style: italic; -fx-font-weight: bold; -fx-font-size: 20;" text="=Cafetería Service" textFill="#578af2" />
            </VBox>
        </VBox>
    </top>
    <bottom>
        <VBox alignment="CENTER">
            <Hyperlink text="¿Olvidaste tu contraseña?"/>
        </VBox>
    </bottom>
    <center>
        <VBox style="-fx-padding: 5">
            <VBox spacing="18" styleClass="panel-bg" style="-fx-padding: 20" alignment="CENTER">
                <VBox spacing="10" alignment="CENTER">
                    <HBox spacing="10.0" style="-fx-alignment: center_left">
                        <Label text="Usuario: "/>
                        <TextField fx:id="usuario" promptText="Usuario" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <HBox spacing="10.0" style="-fx-alignment: center_left">
                        <Label text="Contraseña: "/>
                        <PasswordField fx:id="contrasena" promptText="Contraseña" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <Label fx:id="loginStatus"/>
                </VBox>
                <Button text="Iniciar Sesión" onAction="#handleLogin"/>
            </VBox>
        </VBox>
    </center>
</BorderPane>

