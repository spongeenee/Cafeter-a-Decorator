<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.image.ImageView?>

<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.ComboBox?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.demo1.CafeteriaController"
            style="-fx-background-color: #cfcfcf">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>
    <top>
        <VBox alignment="CENTER">
            <Label text="Super máquina de Boba Tea" style="-fx-padding: 10; -fx-font-weight: bold; -fx-font-size: 20"/>
        </VBox>
    </top>
    <left>
        <VBox spacing="10" style="-fx-padding: 10; -fx-background-color: #ededed">
            <Label text="Producto"/>
            <ComboBox fx:id="product" maxWidth="Infinity" VBox.vgrow="ALWAYS" onAction="#selectProduct" disable="true"/>
        </VBox>
    </left>
    <center>
        <VBox spacing="10" style="-fx-padding: 10; -fx-background-color: #ededed">
            <Label text="Lista de Extras"/>
            <ComboBox fx:id="extra" maxWidth="Infinity" VBox.vgrow="ALWAYS" disable="true"/>
            <Button fx:id="addProduct" text="Agregar" onAction="#addProduct" disable="true" maxWidth="Infinity" VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>
    <right>
        <VBox spacing="10" style="-fx-padding: 10; -fx-background-color: #ededed">
            <TextArea fx:id="registro" editable="false" VBox.vgrow="ALWAYS" maxWidth="Infinity"/>
            <HBox alignment="CENTER">
                <Label text="Total: $"/>
                <Label fx:id="total" text="0"/>
                <Label text=".00"/>
            </HBox>
        </VBox>
    </right>
    <bottom>
            <HBox alignment="CENTER" spacing="12" style="-fx-padding: 20">
                <Button fx:id="start" text="Empezar orden" onAction="#startOrder"/>
                <Button fx:id="restart" text="Reiniciar orden" onAction="#restartOrder" disable="true"/>
                <Button fx:id="finish" text="Terminar orden" onAction="#finishOrder" disable="true"/>
            </HBox>
    </bottom>
</BorderPane>
